{
  "$schema": "./node_modules/@angular/cli/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "calculateur-interets": {
      "projectType": "application",
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:browser",
          "options": {
            "outputPath": "dist/calculateur-interets",
            "index": "src/index.html",
            "main": "src/main.ts",
            "polyfills": ["zone.js"],
            "tsConfig": "tsconfig.json",
            "styles": ["src/styles.css"]
          }
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "options": {
            "buildTarget": "calculateur-interets:build",
            "poll": 2000
          }
        }
      }
    }
  }
}